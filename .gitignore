# Python virtual environments
.venv/
**/.venv/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.pyc.*
*.pyo
*$py.class
*.so
*.pyd

# C extensions / build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg
*.whl

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
*.cover

# Type checking / linting / tooling caches
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/

# Jupyter
.ipynb_checkpoints/

# Misc temporary files (often created by apps/tests)
*.log
*.tmp
tmp/
temp/
*.bak
*.swp
*~

